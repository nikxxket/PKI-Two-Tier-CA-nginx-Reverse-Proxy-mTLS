[ req ]
default_bits        = 2048
prompt              = no
default_md          = sha256
distinguished_name  = dn
req_extensions      = v3_req

[ dn ]
C  = RU
ST = Moscow
L  = Moscow
O  = MyLab
OU = IT Department
CN = lab.local

[ v3_req ]
basicConstraints = CA:FALSE
keyUsage         = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth
subjectAltName   = @alt_names

[ alt_names ]
DNS.1 = lab.local
DNS.2 = api.lab.local
DNS.3 = app.lab.local
DNS.4 = localhost
